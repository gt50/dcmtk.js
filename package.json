{
    "name": "@ubercode/dcmtk",
    "version": "0.6.3",
    "description": "Type-safe Node.js wrapper for DCMTK (DICOM Toolkit) command-line utilities",
    "author": "Michael Lee Hobbs <michael.lee.hobbs@gmail.com> (https://github.com/MichaelLeeHobbs)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MichaelLeeHobbs/dcmtk.js.git"
    },
    "homepage": "https://github.com/MichaelLeeHobbs/dcmtk.js#readme",
    "bugs": {
        "url": "https://github.com/MichaelLeeHobbs/dcmtk.js/issues"
    },
    "keywords": [
        "dicom",
        "dcmtk",
        "medical-imaging",
        "pacs",
        "typescript",
        "dicom-toolkit",
        "healthcare",
        "hl7"
    ],
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./tools": {
            "import": {
                "types": "./dist/tools.d.ts",
                "default": "./dist/tools.js"
            },
            "require": {
                "types": "./dist/tools.d.cts",
                "default": "./dist/tools.cjs"
            }
        },
        "./servers": {
            "import": {
                "types": "./dist/servers.d.ts",
                "default": "./dist/servers.js"
            },
            "require": {
                "types": "./dist/servers.d.cts",
                "default": "./dist/servers.cjs"
            }
        },
        "./dicom": {
            "import": {
                "types": "./dist/dicom.d.ts",
                "default": "./dist/dicom.js"
            },
            "require": {
                "types": "./dist/dicom.d.cts",
                "default": "./dist/dicom.cjs"
            }
        },
        "./utils": {
            "import": {
                "types": "./dist/utils.d.ts",
                "default": "./dist/utils.js"
            },
            "require": {
                "types": "./dist/utils.d.cts",
                "default": "./dist/utils.cjs"
            }
        }
    },
    "typesVersions": {
        "*": {
            "tools": [
                "dist/tools.d.ts"
            ],
            "servers": [
                "dist/servers.d.ts"
            ],
            "dicom": [
                "dist/dicom.d.ts"
            ],
            "utils": [
                "dist/utils.d.ts"
            ]
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "build:watch": "tsup --watch",
        "test": "vitest run",
        "test:all": "vitest run --config vitest.all.config.ts --coverage",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "lint": "eslint --max-warnings 0 .",
        "lint:fix": "eslint --fix --max-warnings 0 .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist coverage",
        "prepare": "husky",
        "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run lint:fix && pnpm run test:coverage",
        "preversion": "pnpm run lint && pnpm run test",
        "postversion": "git push && git push --tags",
        "version:major": "pnpm version major",
        "version:minor": "pnpm version minor",
        "version:patch": "pnpm version patch",
        "dry-run": "npm pack --dry-run",
        "generate": "tsx scripts/generateDictionary.ts"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix --max-warnings 0 --no-warn-ignored",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/node": "25.3.3",
        "@vitest/coverage-v8": "4.0.18",
        "eslint": "10.0.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "fast-check": "4.5.3",
        "globals": "17.4.0",
        "husky": "9.1.7",
        "lint-staged": "16.3.1",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "tsup": "8.5.1",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.56.1",
        "vitest": "4.0.18"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "dependencies": {
        "fast-xml-parser": "5.4.1",
        "stderr-lib": "2.2.0",
        "tree-kill": "1.2.2",
        "zod": "4.3.6"
    }
}
